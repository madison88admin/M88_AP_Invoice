# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ap_invoice_db"

# Azure AD / MSAL
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_REDIRECT_URI=http://localhost:3001/auth/callback

# JWT Secret
JWT_SECRET=your-jwt-secret-key

# Azure Form Recognizer
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_FORM_RECOGNIZER_KEY=your-form-recognizer-key

# QuickBooks
QUICKBOOKS_CLIENT_ID=your-qb-client-id
QUICKBOOKS_CLIENT_SECRET=your-qb-client-secret
QUICKBOOKS_REDIRECT_URI=http://localhost:3001/auth/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Microsoft Graph API
GRAPH_API_CLIENT_ID=your-graph-client-id
GRAPH_API_CLIENT_SECRET=your-graph-client-secret
GRAPH_API_TENANT_ID=your-tenant-id
