# Server
PORT=3001
NODE_ENV=development

# Database
# Local dev: DATABASE_URL="postgresql://user:password@localhost:5432/ap_invoice_db"
# Self-hosted Supabase: DATABASE_URL="postgresql://supabase_admin:POSTGRES_PASSWORD@5.223.78.194:5432/postgres?schema=AP_Invoice"

# Azure AD / MSAL
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# JWT Secret (for development/testing)
JWT_SECRET=your-jwt-secret-key

# Azure Form Recognizer
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_FORM_RECOGNIZER_KEY=your-form-recognizer-key

# Anthropic (Claude) - OCR fallback when Azure not configured
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini - OCR fallback for low-confidence extractions
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_THRESHOLD=70

# Groq - OCR fallback with higher free-tier limits
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TEXT_LENGTH=8000

# QuickBooks
QUICKBOOKS_CLIENT_ID=your-qb-client-id
QUICKBOOKS_CLIENT_SECRET=your-qb-client-secret
QUICKBOOKS_REDIRECT_URI=http://localhost:3001/auth/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Microsoft Graph API
GRAPH_API_CLIENT_ID=your-graph-client-id
GRAPH_API_CLIENT_SECRET=your-graph-client-secret
GRAPH_API_TENANT_ID=your-tenant-id

# NextGen (cookie-based auth — uses NextGen login credentials)
NEXTGEN_API_URL=https://nextgen.madison88.com
NEXTGEN_USERNAME=your-nextgen-username
NEXTGEN_PASSWORD=your-nextgen-password

# Approver emails
COORDINATOR_EMAIL=coordinator@madison88.com
PURCHASING_MANAGER_EMAIL=purchasing-manager@madison88.com
MLO_ACCOUNT_HOLDER_EMAIL=mlo-account-holder@madison88.com
MLO_PLANNING_MANAGER_EMAIL=planning-manager@madison88.com
SR_MANAGER_EMAIL=sr-manager@madison88.com
MS_POLLY_EMAIL=ms-polly@madison88.com
ACCOUNTING_EMAIL=accounting@madison88.com
ACCOUNTING_SUPERVISOR_EMAIL=accounting-supervisor@madison88.com

# Escalation email
VP_OPERATIONS_EMAIL=chris.a@madison88.com
