# AP Invoice - Environment Variables for Web App
# 
# IMPORTANT: For Netlify deployment, set these in the Netlify Dashboard:
#   Site Settings > Environment Variables
#
# DO NOT commit a .env file to git. The .env is in .gitignore.

# Supabase Configuration
# If using a local Supabase instance (dev only):
# VITE_SUPABASE_URL=http://5.223.78.194:8000
#
# For production, use a public Supabase URL:
VITE_SUPABASE_URL=https://your-project.supabase.co

# Replace with the actual anon key from your Supabase project
# In Netlify, set this as: VITE_SUPABASE_ANON_KEY=paste_your_actual_key_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Override API base URL (defaults to same origin)
# VITE_API_URL=