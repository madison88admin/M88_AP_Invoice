generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id                      String   @id @default(uuid())
  name                    String
  name_aliases            String[]
  beneficiary_name        String?
  supplier_location       String?
  invoice_template_type   InvoiceTemplateType
  
  // Bank details
  bank_name               String?
  bank_name_alt           String[]
  bank_address            String?
  account_number          String?
  account_number_alt      String[]
  swift_code              String?
  swift_code_alt          String[]
  iban                    String?
  sort_code               String?
  aba_routing_number      String?
  intermediary_bank_name  String?
  intermediary_bank_swift String?
  has_multiple_accounts   Boolean  @default(false)
  
  // Tax IDs
  gstin_number            String?
  bir_tin                 String?
  vat_number              String?
  eori_number             String?
  
  contact_email           String?
  is_active               Boolean  @default(true)
  onboarded_by            String?
  bank_verified_at        DateTime?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  invoices                Invoice[]
  
  @@index([name])
  @@index([is_active])
  @@map("APInvoice_Vendor")
}

model Invoice {
  id                    String        @id @default(uuid())
  invoice_number        String
  revision              Int           @default(1)
  invoice_date          DateTime?
  invoice_received_date DateTime?
  due_date              DateTime?
  
  // Amounts
  subtotal              Decimal?
  tax_amount            Decimal?
  discount_amount       Decimal?
  bank_charges          Decimal?
  freight_charges       Decimal?
  additional_charges    Decimal?
  courier_charges       Decimal?
  handling_fee          Decimal?
  tt_charge             Decimal?
  setup_charge          Decimal?
  sample_charge         Decimal?
  min_order_charge      Decimal?
  finance_surcharge     Decimal?
  total_amount          Decimal
  currency              String        @default("USD")
  invoice_currency_original String?
  exchange_rate_to_usd  Decimal?
  
  // Vendor
  vendor_id             String
  vendor                Vendor        @relation(fields: [vendor_id], references: [id])
  vendor_name_raw       String

  // Address / entity fields extracted from invoice
  ship_to               String?
  sold_to               String?

  // PO & order details
  customer_po_number    String?
  mpo_number            String?
  mpo_base_number       String?
  mpo_order_sequence    String?
  material_code         String?
  material_name         String?
  brand_code            String?
  brand                 String?
  brand_tier            BrandTier?
  season                String?
  order_type            OrderType?
  qty_shipped           Int?
  incoterm              String?
  hs_code               String?
  grand_total           Decimal?
  
  // Invoice classification
  invoice_type          InvoiceType
  invoice_template_type InvoiceTemplateType?
  category              InvoiceCategory @default(TRIMS)
  parent_invoice_id     String?
  parent_invoice        Invoice?      @relation("PItoCI", fields: [parent_invoice_id], references: [id])
  child_invoices        Invoice[]     @relation("PItoCI")
  
  // Date ranges
  date_range_start      DateTime?
  date_range_end        DateTime?
  
  // Status & routing
  status                InvoiceStatus @default(RECEIVED)
  approval_tier         Int?
  current_approver_role String?
  priority_flag         Boolean       @default(false)
  priority_pay_date     DateTime?
  is_urgent             Boolean       @default(false)
  
  // Validation
  is_duplicate          Boolean       @default(false)
  ocr_confidence_score  Decimal?
  is_handwritten        Boolean       @default(false)
  ocr_raw_data          Json?
  po_validation         Json?
  exception_reasons     ExceptionReason[]
  
  // Extracted bank info (fallback when vendor bank details are missing)
  bank_name             String?
  swift_code            String?
  account_number        String?
  
  // Duplicate detection hash
  invoice_hash          String?
  
  // Bank matching
  bank_match_status     String?
  bank_match_details    Json?
  
  // QuickBooks
  qb_memo               String?
  qb_account_class      String?
  qb_posted_at          DateTime?
  
  // Filing
  sharepoint_folder_url String?
  sharepoint_filed_at   DateTime?
  
  // Bill-to
  bill_to_entity        BillToEntity  @default(MADISON_88_LTD)
  
  // Payment
  payment_terms         String?
  payment_penalty_rate  Decimal?
  
  // Payment confirmation
  confirmation_sent_at  DateTime?
  
  // Meta
  source                InvoiceSource @default(EMAIL)
  raw_file_url          String?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt
  
  signatures            Signature[]
  stage_timestamps      StageTimestamp[]
  audit_logs            AuditLog[]
  payments              Payment[]
  exceptions            Exception[]
  follow_up_tasks       FollowUpTask[]
  payment_confirmations PaymentConfirmation[]
  invoice_lines         InvoiceLine[]
  workflow_actions      InvoiceWorkflowAction[]
  
  @@index([vendor_id])
  @@index([status])
  @@index([invoice_date])
  @@index([invoice_type])
  @@index([bill_to_entity])
  @@index([approval_tier])
  @@index([invoice_hash])
  @@index([invoice_number, vendor_id, invoice_type])
  @@index([mpo_base_number, mpo_order_sequence, material_code])
  @@map("APInvoice_Invoice")
}

model Signature {
  id            String        @id @default(uuid())
  invoice_id    String
  invoice       Invoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  signatory_name String
  signatory_role SignatoryRole
  signed_at     DateTime?
  signature_type SignatureType
  ocr_detected  Boolean       @default(false)
  invoice_revision Int        @default(1)
  approval_status String      @default("PENDING")
  invalidated_at DateTime?
  invalidation_reason String?
  created_at    DateTime      @default(now())
  
  @@index([invoice_id])
  @@index([signatory_role])
  @@map("APInvoice_Signature")
}

model InvoiceLine {
  id                  String   @id @default(uuid())
  invoice_id          String
  invoice             Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  line_number         Int
  description         String?
  mpo_base_number     String?
  mpo_order_sequence  String?
  material_code       String?
  material_name       String?
  quantity            Decimal?
  selling_quantity    Decimal?
  unit_price          Decimal?
  line_amount         Decimal?
  matched_nextgen_line_id String?
  match_level         String?
  match_confidence    Decimal?
  match_status        String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@unique([invoice_id, line_number])
  @@index([mpo_base_number, mpo_order_sequence, material_code])
  @@map("APInvoice_InvoiceLine")
}

model InvoiceWorkflowAction {
  id                String   @id @default(uuid())
  invoice_id        String
  invoice           Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_revision  Int
  action            String
  from_stage        String?
  to_stage          String?
  reason            String?
  performed_by      String
  performed_by_role String?
  created_at        DateTime @default(now())

  @@index([invoice_id, created_at])
  @@map("APInvoice_WorkflowAction")
}

model StageTimestamp {
  id          String        @id @default(uuid())
  invoice_id  String
  invoice     Invoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  stage       InvoiceStatus
  entered_at  DateTime      @default(now())
  exited_at   DateTime?
  sla_hours   Int
  is_breached Boolean       @default(false)
  
  @@index([invoice_id])
  @@index([stage])
  @@map("APInvoice_StageTimestamp")
}

model AuditLog {
  id          String   @id @default(uuid())
  invoice_id  String?
  invoice     Invoice? @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  action      String
  performed_by String?
  note        String?
  created_at  DateTime @default(now())
  
  @@index([invoice_id])
  @@index([created_at])
  @@map("APInvoice_AuditLog")
}

model Payment {
  id            String        @id @default(uuid())
  invoice_id    String
  invoice       Invoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  vendor_id     String?
  amount        Decimal       @db.Decimal(15, 2)
  currency      String        @default("USD")
  payment_date DateTime
  status        String        @default("SCHEDULED")
  batch_id      String?
  batch         PaymentBatch? @relation(fields: [batch_id], references: [id])
  paid_at       DateTime?
  reference     String?
  selected_for_batch Boolean  @default(false)
  selected_by   String?
  selected_at   DateTime?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  
  @@index([invoice_id])
  @@index([status])
  @@index([selected_for_batch])
  @@map("APInvoice_Payment")
}

model PaymentBatch {
  id               String             @id @default(uuid())
  batch_number          String             @unique
  total_amount          Decimal            @db.Decimal(15, 2)
  payment_count         Int                @default(0)
  currency              String             @default("USD")
  status               PaymentBatchStatus  @default(DRAFT)
  created_by           String?
  processed_by         String?
  processed_at         DateTime?
  submitted_by         String?
  submitted_at         DateTime?
  reviewed_by          String?
  reviewed_at          DateTime?
  review_note          String?
  returned_by          String?
  returned_at          DateTime?
  return_reason        String?
  cancelled_by         String?
  cancelled_at         DateTime?
  cancellation_reason  String?
  payments             Payment[]
  created_at           DateTime           @default(now())
  @@map("APInvoice_PaymentBatch")
}

model PaymentConfirmation {
  id              String   @id @default(uuid())
  invoice_id      String
  invoice         Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  payment_id      String?
  vendor_name     String
  vendor_email    String?
  amount          Decimal  @db.Decimal(15, 2)
  currency        String   @default("USD")
  payment_reference String?
  email_sent      Boolean  @default(false)
  cc_email        String?
  sent_by         String?
  sent_at         DateTime @default(now())
  created_at      DateTime @default(now())

  @@index([invoice_id])
  @@index([sent_at])
  @@map("APInvoice_PaymentConfirmation")
}

model ApiKey {
  id          String   @id @default(uuid())
  key_hash    String   @unique
  key_prefix  String
  name        String
  created_by  String
  created_at  DateTime @default(now())
  revoked_at  DateTime?
  last_used_at DateTime?
  expires_at  DateTime?

  @@index([key_hash])
  @@map("APInvoice_ApiKey")
}

model FollowUpTask {
  id               String   @id @default(uuid())
  invoice_id       String
  invoice          Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  task_type        String
  assigned_to      String
  due_date         DateTime
  status           String   @default("PENDING")
  reminder_count   Int      @default(0)
  last_reminded_at DateTime?
  completed_at     DateTime?
  notes            String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  
  @@index([invoice_id])
  @@index([assigned_to])
  @@index([status])
  @@index([due_date])
  @@map("APInvoice_FollowUpTask")
}

// --- ENUMS ---

enum InvoiceType {
  INVOICE
  PROFORMA
  COMMERCIAL
  SALES
  STATEMENT
  PREPAID
  PROTO_SAMPLE
}

enum InvoiceTemplateType {
  PRO_FORMA
  INVOICE
  COMMERCIAL_INVOICE
  SALES_INVOICE
  PROTO_SAMPLE_INVOICE
  PREPAID_INVOICE
  NO_DATA
}

enum InvoiceStatus {
  RECEIVED
  OCR_PROCESSING
  VALIDATION_PENDING
  EXCEPTION_FLAGGED
  PENDING_COORDINATOR
  PENDING_MANAGER
  PENDING_MLO_ACCOUNT_HOLDER
  PENDING_MLO_PLANNING_MANAGER
  PENDING_SR_MANAGER
  PENDING_POLLY
  PENDING_ACCOUNTING
  APPROVED
  POSTED_TO_QB
  PAYMENT_SCHEDULED
  PAID
  PAYMENT_CONFIRMATION_SENT
  REJECTED
  ON_HOLD
}

enum SignatoryRole {
  COORDINATOR
  PURCHASING_MANAGER
  MLO_ACCOUNT_HOLDER
  MLO_PLANNING_MANAGER
  SR_MANAGER_GLOBAL_PRODUCTION
  MS_POLLY
  ACCOUNTING_REVIEWER
}

enum SignatureType {
  WET
  DIGITAL
  COMPUTER_GENERATED
}

enum OrderType {
  BULK
  SMS
  SAMPLE
}

enum ExceptionReason {
  AMOUNT_MISMATCH
  VENDOR_NOT_FOUND
  DUPLICATE_INVOICE
  MISSING_SIGNATURE
  MISSING_BANK_INFO
  BANK_DETAIL_MISMATCH
  OCR_LOW_CONFIDENCE
  LATE_SUBMISSION
  HANDWRITTEN_DOCUMENT
  MISSING_PO_REFERENCE
  MULTI_PO_CONSOLIDATED
  MISSING_BRAND_TIER
  VENDOR_THRESHOLD_EXCEEDED
  BATCH_THRESHOLD_NOT_MET
  PO_NOT_FOUND
}

enum BillToEntity {
  MADISON_88_LTD
  MADISON_88_HK_LIMITED
}

enum InvoiceSource {
  EMAIL
  MANUAL_UPLOAD
  PORTAL
}

enum InvoiceCategory {
  TRIMS
  YARN
  SAMPLE_CHARGES
  SHIPPING_FREIGHT
  LAB_TESTING
  FACTORY
  FACTORY_AUDIT
  PROFESSIONAL_FEE
  SMS
  CONSULTATION
}

model Exception {
  id                 String          @id @default(uuid())
  invoice_id         String
  invoice            Invoice         @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  reason             ExceptionReason
  detail             String?
  status             ExceptionStatus @default(PENDING)
  resolved_by        String?
  resolution_notes   String?
  resolved_at        DateTime?
  created_at         DateTime        @default(now())
  
  @@index([invoice_id])
  @@index([status])
  @@map("APInvoice_Exception")
}

enum ExceptionStatus {
  PENDING
  RESOLVED
  WAIVED
}

enum PaymentBatchStatus {
  DRAFT
  PENDING_SUPERVISOR_REVIEW
  RETURNED_FOR_CORRECTION
  REVIEWED
  EXPORTED_TO_BANK
  PROCESSING
  PROCESSED
  PARTIALLY_PAID
  FAILED
  CANCELLED
}

enum BrandTier {
  TOP_10
  OTHER
}

model CorrectionLog {
  id                String   @id @default(uuid())
  invoice_id        String?
  vendor_name       String?
  invoice_template_type String?
  raw_text          String?
  original_fields   Json?
  corrected_fields  Json?
  note              String?
  use_count         Int      @default(0)
  last_used_at      DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([vendor_name])
  @@index([invoice_template_type])
  @@index([use_count])
  @@index([created_at])
  @@map("APInvoice_CorrectionLog")
}

model Notification {
  id           String   @id @default(uuid())
  invoice_id   String?
  invoice_number String?
  vendor_name  String?
  title        String
  message      String
  type         String   @default("info") // info, success, warning, error
  category     String   @default("stage") // stage, exception, approval, upload, payment
  target_role  String?  // null = all roles, or specific role
  is_read      Boolean  @default(false)
  read_at      DateTime?
  created_at   DateTime @default(now())

  @@index([target_role])
  @@index([is_read])
  @@index([created_at])
  @@index([invoice_id])
  @@map("APInvoice_Notification")
}
